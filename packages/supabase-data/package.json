{
  "name": "@workspace/supabase-data",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./actions/*": "./src/actions/*",
    "./hooks/*": "./src/hooks/*",
    "./modules/*": "./src/modules/*",
    "./lib/*": "./src/lib/*",
    "./domain-map": "./config/domain-map.json",
    "./repository-plan": "./config/repository-plan.json",
    "./action-semantic-plan": "./config/action-semantic-plan.json",
    "./actions/_shared/require-admin-role": "./src/actions/_shared/require-admin-role.ts",
    "./actions/profiles/get-profile-by-user-id": "./src/actions/profiles/get-profile-by-user-id.ts",
    "./actions/user-access/sync-user-access": "./src/actions/user-access/sync-user-access.ts",
    "./actions/user-roles/get-user-roles-by-user-id": "./src/actions/user-roles/get-user-roles-by-user-id.ts",
    "./actions/user-roles/sync-user-roles": "./src/actions/user-roles/sync-user-roles.ts",
    "./lib/auth-is-admin": "./src/lib/auth-is-admin.ts",
    "./lib/supabase-repository-error": "./src/lib/supabase-repository-error.ts",
    "./modules/profiles/domain/dto/profile.dto": "./src/modules/profiles/domain/dto/profile.dto.ts",
    "./modules/profiles/domain/ports/profile-repository.port": "./src/modules/profiles/domain/ports/profile-repository.port.ts",
    "./modules/profiles/infrastructure/repositories/profile-supabase.repository": "./src/modules/profiles/infrastructure/repositories/profile-supabase.repository.ts",
    "./modules/user-access/domain/dto/user-access.dto": "./src/modules/user-access/domain/dto/user-access.dto.ts",
    "./modules/user-roles/domain/dto/user-role.dto": "./src/modules/user-roles/domain/dto/user-role.dto.ts",
    "./modules/user-roles/domain/ports/user-role-repository.port": "./src/modules/user-roles/domain/ports/user-role-repository.port.ts",
    "./modules/user-roles/infrastructure/repositories/user-role-supabase.repository": "./src/modules/user-roles/infrastructure/repositories/user-role-supabase.repository.ts"
  },
  "scripts": {
    "lint": "oxlint",
    "format": "oxfmt --write",
    "test": "mkdir -p coverage/.tmp && vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "check:exports": "publint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.102.1",
    "@workspace/logging": "workspace:*",
    "@workspace/supabase-auth": "workspace:*",
    "@workspace/supabase-infra": "workspace:*",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.83.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.1.0",
    "@workspace/typescript-config": "workspace:*",
    "@workspace/vitest-config": "workspace:*",
    "publint": "^0.3.18",
    "react": "^19.1.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
