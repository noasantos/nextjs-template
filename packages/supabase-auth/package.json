{
  "name": "@workspace/supabase-auth",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./browser/*": "./src/browser/*.ts",
    "./server/route-handlers/*": "./src/server/route-handlers/*.ts",
    "./server/*": "./src/server/*.ts",
    "./session/*": "./src/session/*.ts",
    "./shared/*": "./src/shared/*.ts",
    "./proxy/*": "./src/proxy/*.ts",
    "./testing/*": "./src/testing/*.ts"
  },
  "scripts": {
    "lint": "oxlint .",
    "lint:strict": "oxlint --deny-warnings .",
    "typecheck": "tsc --noEmit",
    "check:exports": "publint"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@workspace/auth-config": "workspace:*",
    "@workspace/logging": "workspace:*",
    "@workspace/supabase-infra": "workspace:*",
    "next": "^16.2.3",
    "react": "^19.2.5",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.10",
    "@workspace/typescript-config": "workspace:*",
    "oxlint": "^1.59.0",
    "publint": "^0.3.18",
    "typescript": "^6.0.2"
  }
}
