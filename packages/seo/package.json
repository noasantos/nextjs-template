{
  "name": "@workspace/seo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "oxlint",
    "format": "oxfmt --write",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && node -e \"const fs=require('node:fs');fs.mkdirSync('dist',{recursive:true});fs.writeFileSync('dist/.turbo-build','');\"",
    "check:exports": "publint"
  },
  "devDependencies": {
    "@workspace/typescript-config": "workspace:*",
    "publint": "^0.3.18",
    "typescript": "^6.0.2"
  }
}
