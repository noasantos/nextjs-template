{
  "name": "@workspace/vitest-config",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2"
  },
  "exports": {
    "./db": {
      "types": "./src/db.ts",
      "default": "./src/db.ts"
    },
    "./node": {
      "types": "./src/node.ts",
      "default": "./src/node.ts"
    },
    "./react": {
      "types": "./src/react.ts",
      "default": "./src/react.ts"
    }
  }
}
