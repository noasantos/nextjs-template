{
  "name": "@workspace/vitest-config",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3"
  },
  "exports": {
    "./db": {
      "types": "./src/db.ts",
      "default": "./src/db.ts"
    },
    "./node": {
      "types": "./src/node.ts",
      "default": "./src/node.ts"
    },
    "./react": {
      "types": "./src/react.ts",
      "default": "./src/react.ts"
    }
  }
}
