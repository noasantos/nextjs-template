{
  "name": "turbo-monorepo-template",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "dotenv -e .env -- turbo build --filter=./apps/*",
    "dev": "dotenv -e .env.local -- turbo dev",
    "lint": "dotenv -e .env -- turbo lint",
    "format": "turbo format",
    "format:check": "prettier --check .",
    "test": "dotenv -e .env.test -- turbo test",
    "test:coverage": "dotenv -e .env.test -- turbo run test --concurrency=1 -- --coverage",
    "test:watch": "dotenv -e .env.test -- turbo test:watch",
    "test:integration:prepare": "pnpm supabase:start && pnpm supabase:db:reset",
    "test:integration": "dotenv -e .env.test -- turbo test:integration",
    "test:integration:reset-local-db-after": "node scripts/test/integration-test-then-reset-db.mjs",
    "test:rls": "dotenv -e .env.test -- turbo test:rls",
    "test:sql": "pnpm supabase test db",
    "test:db": "pnpm test:integration && pnpm test:rls && pnpm test:sql",
    "test:all": "pnpm test:coverage && pnpm test:integration && pnpm test:rls && pnpm test:sql",
    "check:forbidden": "node scripts/ci/check-forbidden.mjs",
    "check:security-smells": "node scripts/ci/check-security-smells.mjs",
    "audit:dependencies": "pnpm audit --audit-level=high",
    "check:docs-drift": "node scripts/ci/check-docs-drift.mjs",
    "bundle:analyze:example": "dotenv -e .env -- pnpm --filter example analyze:bundle",
    "env:check:local": "node scripts/dev/env-check-local.mjs",
    "workflow": "pnpm lint && pnpm typecheck && pnpm build && pnpm format",
    "typecheck": "dotenv -e .env -- turbo typecheck",
    "supabase": "supabase",
    "supabase:start": "pnpm supabase start",
    "supabase:stop": "pnpm supabase stop",
    "supabase:status": "pnpm supabase status",
    "supabase:db:reset": "pnpm supabase db reset",
    "supabase:db:pull": "pnpm supabase db pull",
    "supabase:db:diff": "pnpm supabase db diff",
    "supabase:types:local": "tmpfile=$(mktemp) && pnpm exec supabase gen types typescript --local --schema public,storage > \"$tmpfile\" && mv \"$tmpfile\" packages/supabase-infra/src/types/database.types.ts",
    "supabase:types:linked": "tmpfile=$(mktemp) && pnpm exec supabase gen types typescript --linked --schema public,storage > \"$tmpfile\" && mv \"$tmpfile\" packages/supabase-infra/src/types/database.types.ts",
    "supabase:migration:new": "bash scripts/supabase/migration-new.sh",
    "supabase:migration:stamp": "bash scripts/supabase/migration-stamp.sh",
    "supabase:pgtap:new": "bash scripts/supabase/pgtap-test-new.sh"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "@workspace/vitest-config": "workspace:*",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "supabase": "^2.84.4",
    "turbo": "^2.8.21",
    "typescript": "6.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  }
}
