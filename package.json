{
  "name": "nextjs-supabase-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env.local -- turbo dev",
    "build": "dotenv -e .env.local -- turbo build --filter=./apps/*",
    "lint": "turbo lint",
    "lint:staged": "lint-staged",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "dotenv -e .env.local -- turbo typecheck",
    "knip": "knip --production",
    "test": "dotenv -e .env.test -- turbo test",
    "test:coverage": "dotenv -e .env.test -- turbo test -- --coverage",
    "test:integration": "dotenv -e .env.test -- turbo test:integration",
    "test:rls": "dotenv -e .env.test -- turbo test:rls",
    "test:db": "pnpm exec supabase test db",
    "test:db:all": "pnpm test:integration && pnpm test:rls && pnpm test:db",
    "test:sql": "pnpm test:integration && pnpm test:rls",
    "test:all": "pnpm test:coverage && pnpm test:sql",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install",
    "workflow": "pnpm lint && pnpm check:workspace-imports && pnpm check:cursor-rules-parity && pnpm typecheck && pnpm build && pnpm format",
    "hooks:install": "lefthook install",
    "hooks:uninstall": "lefthook uninstall",
    "supabase:start": "pnpm supabase start",
    "supabase:stop": "pnpm supabase stop",
    "supabase:status": "pnpm supabase status",
    "supabase:db:reset": "pnpm supabase db reset",
    "supabase:types:local": "supabase gen types typescript --local > packages/supabase-infra/src/types/database.types.ts",
    "supabase:types:linked": "supabase gen types typescript --linked > packages/supabase-infra/src/types/database.types.ts",
    "codegen:domain-map:validate": "tsx scripts/codegen/validate-domain-map-cli.ts",
    "codegen:domain-map:validate:example": "tsx scripts/codegen/validate-domain-map-cli.ts -- --types packages/codegen-tools/fixtures/database.types.mock.ts --map config/domain-map.example.json",
    "codegen:domain-map:sync": "tsx scripts/codegen/sync-domain-map-cli.ts",
    "codegen:snapshot-types": "tsx scripts/codegen/snapshot-types-for-codegen-cli.ts",
    "codegen:backend": "tsx scripts/codegen/backend-codegen-cli.ts",
    "codegen:backend:check:example": "tsx scripts/codegen/backend-codegen-cli.ts --check --plan config/repository-plan.example.json --types packages/codegen-tools/fixtures/database.types.mock.ts --map config/domain-map.example.json",
    "codegen:repository-plan:validate": "tsx scripts/codegen/validate-repository-plan-cli.ts",
    "codegen:repository-plan:validate:example": "tsx scripts/codegen/validate-repository-plan-cli.ts -- --strict --plan config/repository-plan.example.json --types packages/codegen-tools/fixtures/database.types.mock.ts --map config/domain-map.example.json",
    "codegen:repository-plan:context": "tsx scripts/codegen/repository-plan-context-cli.ts",
    "codegen:sandbox": "tsx scripts/codegen/sandbox-run.ts",
    "codegen:sandbox:clean": "tsx scripts/codegen/sandbox-clean.ts",
    "codegen:actions-hooks": "tsx scripts/codegen/actions-hooks-cli.ts",
    "codegen:actions-semantic-plan": "tsx scripts/codegen/actions-semantic-plan.ts",
    "codegen:actions-fill-todos": "tsx scripts/codegen/actions-fill-todos.ts",
    "codegen:generate-action-tests": "tsx scripts/codegen/generate-action-tests.ts",
    "codegen:generate-hook-tests": "tsx scripts/codegen/generate-hook-tests.ts",
    "codegen:generate-tests": "pnpm codegen:generate-action-tests --write && pnpm codegen:generate-hook-tests --write",
    "codegen:generate-rls-policies": "tsx scripts/codegen/generate-rls-policies.ts",
    "codegen:generate-index-migrations": "tsx scripts/codegen/generate-index-migrations.ts",
    "codegen:mark-autogenerated": "tsx scripts/codegen/mark-autogenerated-files.ts",
    "codegen:full-pipeline": "tsx scripts/codegen/full-pipeline.ts",
    "codegen:full-pipeline:clean": "tsx scripts/codegen/full-pipeline.ts --skip-tests",
    "codegen:full-pipeline:ci": "tsx scripts/codegen/full-pipeline.ts --skip-validation",
    "supabase:migration:new": "bash scripts/supabase/migration-new.sh",
    "planning:new:task": "tsx scripts/planning/new-item.ts new-task",
    "action:new": "tsx scripts/actions/new-action.ts",
    "edge:new": "tsx scripts/edge/new-edge-function.ts",
    "skills:update": "tsx scripts/skills/update-skills.ts",
    "skills:validate": "tsx scripts/skills/validate-skills.ts",
    "skills:sync-cursor": "bash scripts/skills/sync-cursor-skills.sh",
    "skills:report": "tsx scripts/skills/generate-report.ts",
    "check:forbidden": "node scripts/ci/check-forbidden.mjs",
    "check-forbidden-patterns": "bash scripts/ci/check-forbidden-patterns.sh",
    "check-type-escapes": "node scripts/ci/check-type-escapes.mjs",
    "check:workspace-imports": "node scripts/ci/check-workspace-imports.mjs",
    "check:cursor-rules-parity": "node scripts/ci/check-cursor-rules-parity.mjs",
    "sync:cursor-rules-docs": "node scripts/ci/sync-cursor-rules-to-docs.mjs",
    "check:security-smells": "node scripts/ci/check-security-smells.mjs",
    "check:docs-drift": "node scripts/ci/check-docs-drift.mjs",
    "env:check:local": "node scripts/dev/env-check-local.mjs",
    "seed:local-users": "tsx scripts/qa/seed-local-test-users.ts"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.47.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "posthog-js": "^1.365.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@elsikora/git-branch-lint": "^1.2.2",
    "@playwright/test": "^1.59.1",
    "@supabase/supabase-js": "^2.102.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.3",
    "dependency-cruiser": "^17.3.10",
    "dotenv": "^17.4.1",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^29.0.2",
    "knip": "^6.3.0",
    "lefthook": "^2.1.5",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "supabase": "^2.87.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "brace-expansion": ">=5.0.5",
      "basic-ftp": ">=5.2.0",
      "handlebars": ">=4.7.9",
      "lodash": ">=4.18.0",
      "minimatch@^3.0.0": "3.1.4",
      "minimatch@^9.0.0": "9.0.7",
      "path-to-regexp": ">=8.4.0",
      "picomatch@^2.0.0": ">=2.3.2",
      "picomatch@^4.0.0": ">=4.0.4"
    }
  }
}
