# =============================================================================
# Environment template (commit this file). Real values go in `.env.local` (gitignored).
# =============================================================================
#
# Quick start
#   cp .env.example .env.local   # pnpm dev (turbo loads .env.local)
#   cp .env.example .env         # pnpm build / lint / typecheck (turbo loads .env)
#   Fill variables below. Restart after changes.
#
# Layout (typical monorepo)
#   .env.example   — this file (placeholders, safe to commit)
#   .env.local     — your secrets and local overrides (never commit)
#   .env           — optional; some scripts use it for CI/production-style runs
#
# How commands load env (check root package.json / turbo tasks)
#   Dev often uses `.env.local`; build/lint may use `.env`. One root file is shared by all apps.
#
# Rules of thumb
#   - Prefix browser-exposed vars with NEXT_PUBLIC_ (anything else stays server-only).
#   - Do not put service role keys or production secrets in `.env.example` or committed files.
#   - When you add a new variable, document it here with a short comment.
#
# Deeper guides (optional)
#   - Local Supabase URLs and CLI: docs/guides/supabase-setup.md
#   - Observability env behavior: docs/guides/observability-architecture.md
#   - SEO / metadata / robots / sitemap: docs/guides/seo.md
#
# =============================================================================

# --- Canonical site URL (metadataBase, Open Graph, sitemap, canonical links)
# `next build` (NODE_ENV=production) requires https + a public hostname — not localhost (see next.config.mjs).
# Placeholder below lets local `pnpm build` succeed; replace with your real origin before deploy.
# For day-to-day `pnpm dev`, override in `.env.local` with http://localhost:3000 if you prefer.
NEXT_PUBLIC_SITE_URL=https://example.com

# --- Default locale label (must match apps/example/i18n/routing.ts defaultLocale).
# Actual <html lang> is driven by the [locale] URL segment (next-intl).
NEXT_PUBLIC_DEFAULT_LOCALE=en

# --- Search indexing (robots.txt + sitemap generation for apps/example)
# Set to true only for the production deployment you want indexed. Use false or unset on preview/staging/local.
ROBOTS_ALLOW=false

# --- Enforcing CSP with per-request nonces (apps/example proxy.ts + layout)
# Opt-in: when "1", omits CSP-Report-Only from next.config and sets Content-Security-Policy in proxy.
# Requires dynamic rendering (see app/[locale]/layout.tsx). Verify in browser before enabling in production.
# CSP_ENFORCE=1

# --- App URL (Next.js origin: auth callbacks, redirects, links)
NEXT_PUBLIC_AUTH_APP_URL=http://localhost:3000
NEXT_PUBLIC_SPACE_APP_URL=http://localhost:3001

# --- Auth (optional; comma-separated origins, cookie domain)
NEXT_PUBLIC_AUTH_ALLOWED_REDIRECT_ORIGINS=
NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=

# --- Supabase (public / browser-safe only)
# Never list SUPABASE_SERVICE_ROLE_KEY here (committed template). Local stacks often resolve
# it from the CLI when unset; hosted/prod: inject only via the platform secret store.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Feature flags (example)
NEXT_PUBLIC_FEATURE_DASHBOARD=true
NEXT_PUBLIC_FEATURE_ANALYTICS=false

# --- Observability (@workspace/logging) — server-only
# OBSERVABILITY_HASH_SECRET=
# OBSERVABILITY_PERSIST_EVENTS=
# OBSERVABILITY_SERVER_CONSOLE=

# --- Sensitive-route abuse protection (server-only)
# Callback and email-confirm routes call protectSensitiveAuthRoute (see docs/guides/auth-invariants.md).
# - Unset + NODE_ENV=production → routes return 503 until you configure a limiter (fail closed).
# - memory → in-process windowed limits (OK for local dev and single-instance only).
# - off → pass-through (dangerous; not for production).
# Vercel preview/production: set AUTH_RATE_LIMIT_MODE=memory until you add a durable store (Upstash, etc.).
# AUTH_RATE_LIMIT_MODE=memory
