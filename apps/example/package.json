{
  "name": "example",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../../.env.local -- next dev --webpack -p 3000",
    "analyze:bundle": "next build --webpack && node ../../scripts/ci/analyze-next-bundle.mjs .next",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "test": "mkdir -p coverage/.tmp && vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@workspace/brand": "workspace:*",
    "@workspace/forms": "workspace:*",
    "@workspace/logging": "workspace:*",
    "@workspace/supabase-auth": "workspace:*",
    "@workspace/supabase-infra": "workspace:*",
    "@workspace/ui": "workspace:*",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-intl": "^4.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/env": "16.2.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*",
    "@workspace/vitest-config": "workspace:*",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
