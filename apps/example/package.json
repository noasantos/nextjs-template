{
  "name": "example",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env.local -- next dev --turbopack -p 3000",
    "analyze:bundle": "next build --turbopack && node ../../scripts/ci/analyze-next-bundle.mjs .next",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "oxlint",
    "format": "oxfmt --write",
    "test": "mkdir -p coverage/.tmp && vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@next-safe-action/adapter-react-hook-form": "2.0.5",
