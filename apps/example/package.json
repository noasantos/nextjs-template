    "@workspace/forms": "workspace:*",
    "@workspace/logging": "workspace:*",
    "@workspace/safe-action": "workspace:*",
    "@workspace/seo": "workspace:*",
    "@workspace/supabase-auth": "workspace:*",
    "@workspace/supabase-infra": "workspace:*",
    "@workspace/ui": "workspace:*",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-intl": "^4.9.1",
    "next-safe-action": "^8.4.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/env": "16.2.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/react": "^16.3.0",
