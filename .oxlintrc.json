{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "globals": {
    "React": "readonly",
    "process": "readonly"
  },
  "plugins": ["typescript", "react", "jsx-a11y", "import", "nextjs", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "restriction": "warn",
    "nursery": "off"
  },
  "ignorePatterns": [
    "**/database.types.ts",
    "packages/ui/**",
    "packages/vitest-config/src/server-only-stub.ts",
    "packages/brand/src/index.ts"
  ],
  "settings": {
    "next": {
      "rootDir": ["apps/*/", "packages/*/"]
    }
  },
  "rules": {
    "no-console": "error",
    "no-debugger": "error",
    "eqeqeq": ["error", "always"],
    "no-var": "error",
    "prefer-const": "error",
    "no-undefined": "off",
    "no-void": "off",
    "no-use-before-define": "off",
    "complexity": "off",
    "no-unused-vars": [
      "error",
      {
        "vars": "all",
        "args": "after-used",
        "ignoreRestSiblings": true,
        "varsIgnorePattern": "^_|^React$",
        "argsIgnorePattern": "^_",
        "caughtErrorsIgnorePattern": "^_"
      }
    ],
    "typescript/no-explicit-any": "error",
    "typescript/no-non-null-assertion": "error",
    "typescript/no-unsafe-type-assertion": "error",
    "typescript/explicit-function-return-type": "off",
    "typescript/explicit-module-boundary-types": "off",
    "typescript/consistent-type-assertions": [
      "error",
      {
        "assertionStyle": "as",
        "objectLiteralTypeAssertions": "never"
      }
    ],
    "react/react-in-jsx-scope": "off",
    "react/jsx-filename-extension": "off",
    "react/no-multi-comp": "off",
    "react/only-export-components": "off",
    "import/first": "error",
    "import/no-duplicates": "error",
    "import/no-unassigned-import": "off",
    "import/no-default-export": "off",
    "unicorn/no-array-for-each": "off"
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts"],
      "rules": {
        "no-console": "off",
        "no-await-in-loop": "off",
        "import/first": "off",
        "import/no-relative-parent-imports": "off",
        "typescript/no-explicit-any": "off",
        "typescript/no-non-null-assertion": "off",
        "typescript/no-unsafe-type-assertion": "off",
        "typescript/consistent-type-assertions": "off"
      }
    },
    {
      "files": ["**/server/**/*.ts", "**/session/**/*.ts"],
      "rules": {
        "no-console": "error"
      }
    },
    {
      "files": ["**/app/**/_components/web-vitals.tsx"],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["packages/logging/**/*.ts"],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["**/vitest.config.ts"],
      "rules": {
        "import/no-default-export": "off"
      }
    },
    {
      "files": ["apps/example/app/[locale]/(marketing)/page.tsx"],
      "rules": {
        "react/no-danger": "off"
      }
    },
    {
      "files": ["scripts/**/*.ts", "scripts/**/*.mjs"],
      "rules": {
        "no-console": "off",
        "no-plusplus": "off",
        "import/no-relative-parent-imports": "off",
        "unicorn/no-process-exit": "off"
      }
    },
    {
      "files": ["*.cjs", "*.js"],
      "rules": {
        "import/no-commonjs": "off",
        "import/unambiguous": "off",
        "unicorn/prefer-module": "off"
      }
    }
  ]
}
