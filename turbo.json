{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "DENO_DEPLOYMENT_ID",
    "VERCEL",
    "VERCEL_ENV",
    "NEXT_PUBLIC_*",
    "SENTRY_*",
    "SUPABASE_*",
    "TZ",
    "ROBOTS_ALLOW",
    "CSP_ENFORCE",
    "CI"
  ],
  "globalDependencies": [".env.local", ".env.test"],
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": [],
      "cache": true
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"],
      "outputs": [],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": ["**/.tsbuildinfo"],
      "cache": true
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "vitest.config.*"],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$", ".env*", "supabase/**", "tests/**"]
    },
    "test:rls": {
      "dependsOn": ["^build"],
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$", ".env*", "supabase/**", "tests/rls/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
