{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "DENO_DEPLOYMENT_ID",
    "OBSERVABILITY_HASH_SECRET",
    "OBSERVABILITY_PERSIST_EVENTS",
    "OBSERVABILITY_SERVER_CONSOLE",
    "VERCEL",
    "VERCEL_ENV",
    "ROBOTS_ALLOW",
    "NEXT_PUBLIC_AUTH_ALLOWED_REDIRECT_ORIGINS",
    "NEXT_PUBLIC_AUTH_APP_URL",
    "NEXT_PUBLIC_AUTH_COOKIE_DOMAIN",
    "AUTH_RATE_LIMIT_MODE",
    "CSP_ENFORCE",
    "NEXT_PUBLIC_DEFAULT_LOCALE",
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PHASE",
    "SUPABASE_SERVICE_ROLE_KEY",
    "TEST_USER_PASSWORD",
    "TZ"
  ],
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "format": {
      "cache": false,
      "dependsOn": ["^format"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build", "^test"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "vitest.config.ts",
        "vitest.config.mts",
        "tests/**"
      ],
      "outputs": []
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "cache": false,
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "supabase/**",
        "vitest.config.ts",
        "vitest.config.mts",
        "tests/package.json",
        "tests/vitest.integration.config.ts",
        "tests/vitest.rls.config.ts",
        "tests/integration/**",
        "tests/rls/**"
      ],
      "outputs": []
    },
    "test:rls": {
      "dependsOn": ["^build"],
      "cache": false,
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "supabase/**",
        "vitest.config.ts",
        "vitest.config.mts",
        "tests/package.json",
        "tests/vitest.rls.config.ts",
        "tests/rls/**"
      ],
      "outputs": []
    },
    "test:sql": {
      "cache": false,
      "inputs": ["supabase/**"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
